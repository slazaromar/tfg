{
  "name": "tactic-ai-backend",
  "version": "1.0.0",
  "description": "TacticAI REST API — Node.js + Express",
  "main": "src/app.js",
  "scripts": {
    "start":       "node src/app.js",
    "dev":         "nodemon src/app.js",
    "test":        "jest --coverage",
    "test:watch":  "jest --watch",
    "lint":        "eslint src/"
  },
  "dependencies": {
    "axios":          "^1.6.7",
    "bcryptjs":       "^2.4.3",
    "compression":    "^1.7.4",
    "cors":           "^2.8.5",
    "dotenv":         "^16.4.5",
    "express":        "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet":         "^7.1.0",
    "ioredis":        "^5.3.2",
    "jsonwebtoken":   "^9.0.2",
    "morgan":         "^1.10.0",
    "pg":             "^8.11.3",
    "uuid":           "^9.0.0",
    "winston":        "^3.11.0"
  },
  "devDependencies": {
    "eslint":         "^8.57.0",
    "jest":           "^29.7.0",
    "nodemon":        "^3.1.0",
    "supertest":      "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["src/**/*.js", "!src/app.js"]
  }
}
